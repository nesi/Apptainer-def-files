Bootstrap: docker
From: ubuntu:24.04

%environment
    export DEBIAN_FRONTEND="noninteractive"
    export LANG=en_NZ.utf8

%post
    mkdir -p /opt/nesi
    # Update and install system dependencies
    apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y wget

    wget -qO - https://download.sublimetext.com/sublimehq-pub.gpg | tee /etc/apt/keyrings/sublimehq-pub.asc > /dev/null
    echo -e 'Types: deb\nURIs: https://download.sublimetext.com/\nSuites: apt/stable/\nSigned-By: /etc/apt/keyrings/sublimehq-pub.asc' | tee /etc/apt/sources.list.d/sublime-text.sources

    apt-get update && apt-get install sublime-text


    # Clean up apt cache
    rm -rf /var/lib/apt/lists/*


%labels
    Author Wes Harrell
    Version v1.0
    Description Sumblime Text Editor for Geoff
