# This def file has been created based on https://github.com/google-deepmind/alphafold3/blob/main/docker/Dockerfile
Bootstrap: docker
From: nvidia/cuda:12.6.3-base-ubuntu24.04

%environment
    export PATH="/hmmer/bin:/alphafold3_venv/bin:/app/alphafold:$PATH"
    export XLA_FLAGS="--xla_gpu_enable_triton_gemm=false"
    export XLA_PYTHON_CLIENT_PREALLOCATE=true
    export XLA_CLIENT_MEM_FRACTION=0.95

%post
    # Update and install basic dependencies
    apt update --quiet
    apt install --yes --quiet software-properties-common
    apt install --yes --quiet git wget gcc g++ make zlib1g-dev zstd

    # Install Python 3.12
    add-apt-repository ppa:deadsnakes/ppa
    DEBIAN_FRONTEND=noninteractive apt install --yes --quiet python3.12 python3-pip python3.12-venv python3.12-dev

    # Set up Python virtual environment
    python3.12 -m venv /alphafold3_venv
    . /alphafold3_venv/bin/activate
    pip3 install --upgrade pip

    # Install HMMER
    mkdir /hmmer_build /hmmer
    wget http://eddylab.org/software/hmmer/hmmer-3.4.tar.gz --directory-prefix /hmmer_build
    cd /hmmer_build && tar zxf hmmer-3.4.tar.gz && rm hmmer-3.4.tar.gz
    cd /hmmer_build/hmmer-3.4 && ./configure --prefix /hmmer
    cd /hmmer_build/hmmer-3.4 && make -j8
    cd /hmmer_build/hmmer-3.4 && make install
    cd /hmmer_build/hmmer-3.4/easel && make install
    rm -R /hmmer_build

    # Make a place for alphafold to be accessed from
    mkdir -p /app/alphafold/

    # Install alphafold using pip, and copy run_alphafold.py to /app/alphafold
    cd $HOME
    wget https://github.com/google-deepmind/alphafold3/archive/refs/tags/v3.0.2.tar.gz
    tar -xvzf v3.0.2.tar.gz
    # Copy run_alphafold.py to /app/alphafold
    cp alphafold3-3.0.2/run_alphafold.py /app/alphafold/run_alphafold.py
    # Install alphafold using pip
    pip install v3.0.2.tar.gz
    rm -rv v3.0.2.tar.gz alphafold3-3.0.2

    # run build_data
    cd /app/alphafold
    build_data

    # Continue installation after files are copied
    #cd /app/alphafold
    #. /alphafold3_venv/bin/activate
    #pip3 install -r dev-requirements.txt
    #pip3 install --no-deps .
    #build_data

    # Add shebang and make the script executable
    sed -i '1i#!/usr/bin/env python3' /app/alphafold/run_alphafold.py
    chmod +x /app/alphafold/run_alphafold.py

%runscript
    . /alphafold3_venv/bin/activate
    run_alphafold.py

%labels
    Author DeepMind Technologies Limited
    Version AlphaFold 3
    License CC BY-NC-SA 4.0
